translate spanish tmd_job_msg_JP.json/MSG_0264:
	# jp: "[255:00000900]でありながら\n熱しやすく冷めやすいその性格は\n　まるで鶏ガラスープのよう。"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0265:
	# jp: "[255:00000900]スルメイカだのホタルイカだの\nうるせぇってんだ\n足の多い野郎はみんなタコだ！"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0266:
	# jp: "[255:00000900]引いてきた水で火を消せば\nプラマイゼロ\n　といったところでしょうか。"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0267:
	# jp: "[255:00000900]　ハトのフンと４～５０分格闘。\nようやく落としたところへ\n　新たなフンが来てついにフンガイ。"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0268:
	# jp: "[255:00000900]恋愛に悩む思春期のリスナー達を\nバッサリ切り捨てるお悩み相談の\n　コーナーが３０代の女性に大人気。"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0269:
	# jp: "[255:00000900]部下が徹夜で書き上げたレポートを\n　スローモーションで宙へ。"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0270:
	# jp: "[255:00000900]ＣＡと見れば携帯番号を渡す業界人も\nアナタの張りつめた空気を前に\n　思わずそっとメモをしまうでしょう。"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0271:
	# jp: "[255:00000900]目立たないよう黒ずくめで潜入\nするまでは良いのですが\n　空気でなんとなく感づかれます。"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0272:
	# jp: "[255:00000900]日頃から一段腰を落として\n人と接する構えは\n　ドリブルに通じるものがあります。"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0273:
	# jp: "[255:00000900]入浴中もヘルメットが\n　かかせません。"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0274:
	# jp: "[255:00000900]車高が低ければ低いほど\n　いいようです。"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0275:
	# jp: "[255:00000900]殿方のお車を誠心誠意\n　お守りするでござる。"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0276:
	# jp: "[255:00000900]一見誰にでも笑顔で接していますが\nこの人は自分に厳しいとわかると\n　微妙に口角が下がります。"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0277:
	# jp: "[255:00000900]自宅マンションより高価なバイオリンを\n　体の一部であるかのように構えます。"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0278:
	# jp: "[255:00000900]ジダラクマヌカンジダラクマヌカン\nみんなが私に夢中になあれ♪"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0279:
	# jp: "[255:00000900]４番目の彼と５番目の彼の間には\n島を持っているか否かという\n　越えられない壁があります。"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0280:
	# jp: "[255:00000900]オチで値段を言う段取りに\nなっているのに、早い段階で\n　明かしてしまう傾向が。"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0281:
	# jp: "[255:00000900]　割る事が重要なのではありません。　\nいかに美しく、かつ合理的に\n　割るかが重要なのです。"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0282:
	# jp: "[255:00000900]いくら合理的だからといって\n客に寿司を直接手渡すのは\n　やめた方がいいでしょう。"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0283:
	# jp: "[255:00000900]前座ＤＪが\nフロアを温めきれていないと\n　本気で怒りをあらわに。"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0284:
	# jp: "[255:00000900]野球応援用の「かっとばせー」を\nサッカーの際「カットインー」に\n　するなど、応用のきく賢いオンナ。"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0285:
	# jp: "[255:00000900]　人の世話が大好き。当然犬の世話も。\n　色気に乏しいのがタマにキズ。\n　実は犬もそう思っています。"
	# en: " "
	""

translate spanish tmd_job_msg_JP.json/MSG_0286:
